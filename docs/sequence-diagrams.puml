' =====================================================================
' 16. VOLUNTEER TIẾN TRÌNH NHIỆM VỤ + CỘNG ĐIỂM
'     POST /api/v1/campaigns/assignments/:id/advance
'     assigned -> checked_in -> in_progress -> completed
' =====================================================================
@startuml 16-Campaign-AdvanceTask
title Volunteer tiến trình nhiệm vụ + cộng điểm cống hiến
autonumber

actor "Volunteer" as User
participant "Frontend\n(Camera)" as FE
participant "CampaignsController" as Ctrl
participant "CampaignsService" as Svc
participant "StorageService" as Store
participant "PrismaService" as Prisma
database "PostgreSQL" as DB

User -> FE : Bấm "Tiến trình" (+ ảnh minh chứng)
FE -> Ctrl : POST /campaigns/assignments/:id/advance (photo?)
activate Ctrl
Ctrl -> Svc : advance(assignmentId, userId, photo)
activate Svc
opt có ảnh minh chứng
    Svc -> Store : saveImage(photo, 'campaign-proofs')
    Store --> Svc : proofUrl
end
Svc -> Prisma : volunteerProfile.findUnique({ userId })
Prisma -> DB : SELECT FROM volunteer_profiles
Svc -> Prisma : campaignVolunteerAssignment.findUnique({ id })
Prisma -> DB : SELECT FROM campaign_volunteer_assignment
DB --> Prisma : assignment
Prisma --> Svc : assignment
alt assignment.volunteerId != volunteer.id
    Svc --> Ctrl : throw ForbiddenException
    Ctrl --> FE : HTTP 403
end
Svc -> Svc : next = ASSIGN_NEXT[current]
alt assigned -> checked_in
    Svc -> Prisma : update(checkInTime=NOW())
    Prisma -> DB : UPDATE campaign_volunteer_assignment
else checked_in -> in_progress
    Svc -> Prisma : update(ingredientProofUrl, ingredientProofAt)
    Prisma -> DB : UPDATE campaign_volunteer_assignment
else in_progress -> completed
    note right of Svc : Điểm theo role:\nchef=15, waiter=10, shipper=10
    Svc -> Prisma : $transaction(BEGIN)
    Prisma -> DB : BEGIN
    Svc -> Prisma : assignment.update(checkOutTime, cooked/distributionProofUrl)
    Prisma -> DB : UPDATE campaign_volunteer_assignment
    Svc -> Prisma : volunteerProfile.dedicationPoints += points
    Prisma -> DB : UPDATE volunteer_profiles
    Svc -> Prisma : dedicationPointsHistory.create()
    Prisma -> DB : INSERT INTO dedication_points_history
    Svc -> Prisma : $transaction(COMMIT)
    Prisma -> DB : COMMIT
end
Svc --> Ctrl : { status: next }
deactivate Svc
Ctrl --> FE : HTTP 200 { success, data }
deactivate Ctrl
FE --> User : Cập nhật trạng thái
@enduml


