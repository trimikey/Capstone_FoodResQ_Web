Prisma -> DB : BEGIN
Svc -> Prisma : assignment.create(status='assigned')
Prisma -> DB : INSERT INTO campaign_volunteer_assignment
Svc -> Prisma : campaign.update([role]SlotsFilled+=1)
Prisma -> DB : UPDATE kitchen_campaigns
