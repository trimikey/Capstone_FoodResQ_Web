' =====================================================================
' 21. GỬI THÔNG BÁO HỢP NHẤT (DB + WebSocket + FCM)
' =====================================================================
@startuml 21-Notifications-Unified
title Gửi thông báo hợp nhất (DB + WebSocket + FCM)
autonumber

participant "Caller\n(any service)" as Caller
participant "NotificationsService" as Svc
participant "PrismaService" as Prisma
database "PostgreSQL" as DB
participant "NotificationsGateway\n(Socket.IO)" as WS
participant "PushService" as Push
participant "Firebase FCM" as FCM
actor "Thiết bị người dùng" as Dev

Caller -> Svc : notify(userId, { type, title, body, data })
activate Svc
Svc -> Prisma : notification.create()
Prisma -> DB : INSERT INTO notifications
Svc -> WS : emitToUser(userId, 'notification:new', notif)
WS -> Dev : (nếu online) realtime event
Svc -> Push : sendToUser(userId, ...) [async, void]
activate Push
Push -> Prisma : deviceToken.findMany({ userId })
Prisma -> DB : SELECT token FROM device_token WHERE user_id=?
DB --> Prisma : tokens[]
Prisma --> Push : tokens[]
alt không có token
    Push --> Svc : return (no-op)
end
Push -> FCM : sendEachForMulticast(tokens, notification, data)
FCM -> Dev : Push notification
FCM --> Push : responses[]
opt có token lỗi
    Push -> Prisma : deviceToken.deleteMany(invalid)
    Prisma -> DB : DELETE FROM device_token WHERE token IN (...)
end
deactivate Push
Svc --> Caller : notif
deactivate Svc
@enduml


' =====================================================================
' 22. KẾT NỐI WEBSOCKET + XÁC THỰC JWT
' =====================================================================
@startuml 22-WebSocket-Connect
title Kết nối WebSocket + xác thực JWT
autonumber

actor "Người dùng" as User
participant "Frontend\n(socket.io-client)" as FE
participant "NotificationsGateway" as GW
participant "JWT" as JWT

User -> FE : Đăng nhập thành công
FE -> GW : connect (auth.token / Authorization header)
activate GW
alt thiếu token
    GW --> FE : disconnect()
end
GW -> JWT : verify(token, JWT_SECRET)
alt token hợp lệ
    JWT --> GW : { sub: userId }
    GW -> GW : socket.join('user:' + userId)
    GW --> FE : connected
else token sai
    GW --> FE : disconnect()
end
deactivate GW

note over GW
  emitToUser(userId, event, data)
  => server.to('user:'+userId).emit(event, data)
  Events: 'notification:new', 'delivery:location'
end note
@enduml


' =====================================================================
' 23. CRON: HẾT HẠN ĐƠN KHÔNG ĐẾN LẤY (EXPIRE NO-SHOWS)
' =====================================================================
@startuml 23-Cron-ExpireNoShows
title Cron: xử lý đơn quá hạn (no-show, phạt điểm)
autonumber

participant "Cron Scheduler" as Cron
participant "ReservationsService" as Svc
participant "PrismaService" as Prisma
database "PostgreSQL" as DB

Cron -> Svc : expireNoShows()
activate Svc
Svc -> Prisma : reservation.findMany(confirmed, qrExpiresAt<now, take 200)
Prisma -> DB : SELECT FROM reservations\nWHERE status='confirmed' AND qr_expires_at<NOW() LIMIT 200
DB --> Prisma : overdue[]
Prisma --> Svc : overdue[]
loop mỗi đơn quá hạn
    Svc -> Prisma : $transaction(BEGIN)
    Prisma -> DB : BEGIN
    Svc -> Prisma : reservation.update(status='no_show')
    Prisma -> DB : UPDATE reservations
    Svc -> Prisma : $executeRaw (hoàn số lượng)
    Prisma -> DB : UPDATE food_listings SET quantity_remaining+=qty, status='active'
    Svc -> Prisma : receiverProfile.update(reservationsToday-=1)
    Prisma -> DB : UPDATE receiver_profiles
    Svc -> Prisma : $transaction(COMMIT)
    Prisma -> DB : COMMIT
    Svc -> Svc : applyTrustDelta(receiverUserId, -20, 'no_show') [async]
end
Svc --> Cron : count
deactivate Svc
@enduml
