'──────────────────── 14. System Config ──────────────────────
@startuml seq-admin-config
!include _seq-style.iuml
title System Config Sequence Diagram

actor "Admin" as User
participant "ConfigScreen" as Screen
participant "AdminController" as Ctrl
participant "AdminService" as Svc
participant "SystemConfigService" as Cfg
participant "PrismaService" as Repo
database "Database" as DB

User -> Screen : open settings
activate Screen
Screen -> Ctrl : GET /admin/configs
activate Ctrl
Ctrl -> Svc : getConfigs()
Svc -> Cfg : getAll()
Cfg -> Repo : systemConfig.findMany()
Repo -> DB : SELECT system_configs
DB --> Repo : configs
Cfg --> Ctrl : configs
Ctrl --> Screen : return data (200)
deactivate Ctrl
User -> Screen : edit a config value
Screen -> Ctrl : PATCH /admin/configs/:key (value)
activate Ctrl
Ctrl -> Svc : setConfig(key, value, userId)
Svc -> Cfg : set(key, value, userId)
Cfg -> Repo : systemConfig.upsert(key, value, updatedBy)
Repo -> DB : INSERT/UPDATE system_configs
Cfg --> Ctrl : updated config
Ctrl --> Screen : return data (200)
Screen --> User : config saved
deactivate Ctrl
deactivate Screen
@enduml
