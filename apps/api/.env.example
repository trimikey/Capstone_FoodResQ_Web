# ─── Database ────────────────────────────────────────────────────────────────
# Supabase: app chạy qua pooler TRANSACTION MODE (port 6543) + pgbouncer=true
# (session mode 5432 chỉ có 15 slot — cả nhóm dùng chung sẽ dính EMAXCONNSESSION)
DATABASE_URL="postgresql://user:password@host.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10"
# DIRECT_URL (BẮT BUỘC): kết nối session mode 5432 — chỉ dùng cho prisma db push/migrate
DIRECT_URL="postgresql://user:password@host.pooler.supabase.com:5432/postgres"
# Local fallback:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/foodresq"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/foodresq"

# ─── Auth ──────────────────────────────────────────────────────────────────
# Tạo bằng: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_ME"
JWT_REFRESH_SECRET="CHANGE_ME"

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Server ────────────────────────────────────────────────────────────────
PORT=3001
ALLOWED_ORIGINS="http://localhost:3000"

# ─── Email (Resend) ────────────────────────────────────────────────────────
# Đăng ký tại resend.com, lấy API key từ dashboard
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS="re_YOUR_API_KEY_HERE"
MAIL_FROM=FoodResQ <onboarding@resend.dev>

# ─── Firebase Admin ───────────────────────────────────────────────────────
# Lấy từ Firebase Console → Project settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com"
GOOGLE_CLIENT_ID=""
# FIREBASE_PRIVATE_KEY: dán nguyên chuỗi, giữ \n trong 1 dòng (có dấu nháy kép)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_YOUR_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_SERVICE_ACCOUNT=""

# ─── Optional: Push Notifications ─────────────────────────────────────────
# Base64-encoded Firebase Service Account JSON (tùy chọn)
# FIREBASE_SERVICE_ACCOUNT=""
